TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

DATABASE_URL=sqlite:///data/flats.db

SCRAPE_INTERVAL_MINUTES=30

MIN_ROOMS=2
MAX_ROOMS=4
MIN_FLOOR=2
MAX_PRICE=1500
AREAS=Kreuzberg,Friedrichshain,Neukölln
EXCLUDE_KEYWORDS=möbliert,WG

LOG_LEVEL=INFO
LOG_FILE=logs/scraper.log

SCOUT24_BASE_URL=https://www.immobilienscout24.de/Suche/de/berlin/berlin/wohnung-mieten
IMMOWELT_BASE_URL=https://www.immowelt.de/liste/berlin/wohnungen/mieten

# Optional: comma-separated list of public Facebook group URLs to scan for flat posts.
# Replace with groups you trust and verify. These Berlin-focused starters are examples and can be edited.
FACEBOOK_GROUP_URLS=https://www.facebook.com/groups/wohnungen.berlin/,https://www.facebook.com/groups/berlinwohnungen/,https://www.facebook.com/groups/wohnung.berlin/

# Optional: your Facebook session cookie string for groups/pages that require login.
# Example format: c_user=...; xs=...;
FACEBOOK_SESSION_COOKIE=

# Optional: comma-separated list of HTTP proxy URLs to rotate through when scraping.
# Example:
#   PROXIES=http://user:pass@proxy1:8080,http://proxy2:3128
# Leave empty (or omit) to scrape without a proxy. SOCKS proxies are not supported with the default dependencies.
PROXIES=
